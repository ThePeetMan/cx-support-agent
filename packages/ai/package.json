{
  "name": "@cx/ai",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "eval": "tsx src/eval.ts",
    "ingest-pending": "tsx src/ingest-pending.ts",
    "lint": "echo 'no lint configured'"
  },
  "dependencies": {
    "@cx/db": "workspace:*",
    "@cx/shared": "workspace:*",
    "@langchain/core": "^0.3.42",
    "@langchain/langgraph": "^0.2.54",
    "@langchain/openai": "^0.5.5",
    "drizzle-orm": "^0.40.0",
    "dotenv": "^16.4.7",
    "openai": "^4.91.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
