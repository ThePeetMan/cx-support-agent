{
  "name": "cx-support-agent",
  "private": true,
  "version": "0.1.0",
  "description": "AI customer support platform: RAG knowledge base, LangGraph agent, embeddable widget",
  "scripts": {
    "dev": "pnpm --parallel --filter @cx/api --filter @cx/web dev",
    "dev:stack": "bash scripts/dev.sh",
    "dev:api": "pnpm --filter @cx/api dev",
    "dev:web": "pnpm --filter @cx/web dev",
    "dev:worker": "pnpm --filter @cx/api dev:worker",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @cx/db generate",
    "db:migrate": "pnpm --filter @cx/db migrate",
    "db:seed": "pnpm --filter @cx/db seed",
    "db:ingest": "pnpm --filter @cx/ai ingest-pending",
    "eval": "pnpm --filter @cx/ai eval",
    "widget:build": "pnpm --filter @cx/widget build && mkdir -p apps/web/public && cp apps/widget/dist/widget.js apps/web/public/widget.js"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.2"
}
